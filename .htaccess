# Increase PHP Upload Limits
<IfModule mod_php.c>
    php_value upload_max_filesize 300M
    php_value post_max_size 320M
    php_value memory_limit 512M
    php_value max_execution_time 300
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 300M
    php_value post_max_size 320M
    php_value memory_limit 512M
    php_value max_execution_time 300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 300M
    php_value post_max_size 320M
    php_value memory_limit 512M
    php_value max_execution_time 300
</IfModule>
